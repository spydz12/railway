{
  "name": "ai-stock-trade-bot",
  "version": "1.0.0",
  "description": "AI Stock Trade Ideas Telegram Bot - Real market data, strategy-based signals, full trade tracking",
  "private": true,
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:bot": "tsc --project tsconfig.build.json",
    "build:frontend": "next build --webpack",
    "start": "node dist/index.js",
    "start:railway": "node dist/bootstrap/index.js",
    "start:worker": "node dist/bootstrap/startWorkers.js",
    "start:scanner": "node dist/bootstrap/startScanner.js",
    "start:tracking": "node dist/bootstrap/startTracking.js",
    "start:frontend": "next start",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:frontend": "next dev",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.39.3",
    "axios": "^1.6.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "date-fns-tz": "^3.1.3",
    "dotenv": "^16.4.4",
    "fastify": "^4.26.2",
    "lucide-react": "^0.344.0",
    "next": "^16.0.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.64.0",
    "openai": "^6.37.0",
    "p-limit": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.1.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
