# =============================================================
# AI Stock Trade Ideas Bot — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# =============================================================
# SUPABASE (Required)
# =============================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================
# TELEGRAM (Required)
# =============================================================
# 1. Create a bot via @BotFather on Telegram -> get BOT_TOKEN
# 2. Add bot to your channel as admin
# 3. Get channel ID (use @userinfobot or API)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# Optional: Additional language channels (leave empty to disable)
TELEGRAM_CHANNEL_ID_FR=
TELEGRAM_CHANNEL_ID_AR=

# =============================================================
# MARKET DATA PROVIDERS (at least one required)
# =============================================================
# Preferred provider (polygon | alpaca | finnhub | twelvedata)
MARKET_DATA_PROVIDER=polygon

# --- Polygon.io ---
# Free tier: 5 API calls/min, real-time data on paid plans
# Get key at: https://polygon.io/
POLYGON_API_KEY=

# --- Alpaca Markets ---
# Free tier: real-time SIP data with any account
# Get keys at: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_API_SECRET=

# --- Finnhub ---
# Free tier: 60 API calls/min
# Get key at: https://finnhub.io/
FINNHUB_API_KEY=

# --- Twelve Data ---
# Free tier: 8 API calls/min
# Get key at: https://twelvedata.com/
TWELVE_DATA_API_KEY=

# =============================================================
# SCANNER SETTINGS
# =============================================================
# How often to scan for new setups (minutes, minimum 1)
SCAN_INTERVAL_MINUTES=5

# How often to check status of active trade ideas (minutes)
TRACKING_INTERVAL_MINUTES=2

# Maximum trade idea alerts per day
MAX_SIGNALS_PER_DAY=10

# Only scan during US market hours (9:30 AM - 4:00 PM ET, Mon-Fri)
MARKET_SESSION_FILTER=true

# Minimum average daily volume for a stock to be scanned
MIN_VOLUME_FILTER=500000

# Comma-separated list of strategy slugs to enable
ENABLED_STRATEGIES=trend_pullback,breakout_volume,support_bounce

# Allow SELL/SHORT directions (true/false)
ALLOW_SHORT_SELLING=false

# =============================================================
# RISK MANAGEMENT
# =============================================================
# Maximum risk per trade as a percentage of entry price
MAX_RISK_PER_TRADE_PCT=1.0

# Minimum risk/reward ratio to accept a setup
MIN_RISK_REWARD=2.0

# Auto-close trade ideas older than this many hours
MAX_TRADE_AGE_HOURS=72

# =============================================================
# INTERNAL API
# =============================================================
ENABLE_INTERNAL_API=true
API_PORT=3000
API_HOST=0.0.0.0

# Service toggles for split deployment (Railway workers / Vercel dashboard)
ENABLE_SCANNER=true
ENABLE_TRACKING=true
ENABLE_WORKERS=true
ENABLE_CRON=true

# =============================================================
# APPLICATION
# =============================================================
NODE_ENV=production
LOG_LEVEL=info

# =============================================================
# AI TRADE ANALYST (Optional)
# =============================================================
# Enable AI analysis of trade candidates (true/false)
AI_ANALYST_ENABLED=true

# OpenAI API key for AI analysis
OPENAI_API_KEY=

# AI model to use (gpt-4o-mini recommended for cost/speed)
AI_ANALYST_MODEL=gpt-4o-mini

# Minimum AI confidence score to approve signals
AI_APPROVAL_MIN_CONFIDENCE=70

# Maximum AI API calls per day (to control costs)
AI_MAX_CALLS_PER_DAY=50

# =============================================================
# PAPER TRADING MODE (Optional)
# =============================================================
# Enable paper trading mode (signals sent but marked as paper trades)
PAPER_MODE=false
